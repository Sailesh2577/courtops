# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings -> API). .env.local is gitignored, so nothing here is
# published to the public repo.

# Public: safe to ship to the browser. Gated by row level security.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret: full database access. Used ONLY by the seed scripts on your machine.
# Never commit this and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Secret: the operator copilot (Phase 3) calls Gemini server-side with this key.
# Used only in the /api/copilot route handler, never shipped to the browser (no
# NEXT_PUBLIC prefix). Get one from Google AI Studio. GEMINI_MODEL is optional
# and defaults to gemini-2.5-flash.
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash

# Optional: the demo organizer account. The login page pre-fills these and
# `npm run seed:org` creates the account with them. Safe to ship to the browser
# (it is a throwaway demo login). If omitted, the defaults in lib/auth.ts are
# used (sailesh@courtops.demo / courtops-demo).
NEXT_PUBLIC_DEMO_ORG_EMAIL=sailesh@courtops.demo
NEXT_PUBLIC_DEMO_ORG_PASSWORD=courtops-demo
NEXT_PUBLIC_DEMO_ORG_NAME=Sailesh P.
